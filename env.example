# NewPlains.dev Environment Variables
# Copy this file to .env.local and fill in actual values

# ============================================
# FORMSPREE (Contact Form)
# ============================================
# Get your form ID at https://formspree.io — create a form and copy the ID
NEXT_PUBLIC_FORMSPREE_ID=xojnjzgv

# ============================================
# GOOGLE TAG MANAGER
# ============================================
# Get your container ID at https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ============================================
# GOOGLE ANALYTICS 4
# ============================================
# Get your measurement ID from GA4 property settings
NEXT_PUBLIC_GA_ID=G-XXXXXXX

# ============================================
# SITE CONFIG
# ============================================
NEXT_PUBLIC_SITE_URL=https://newplains.dev
NEXT_PUBLIC_SITE_NAME=New Plains LLC
NEXT_PUBLIC_CONTACT_EMAIL=info@newplains.dev

# ============================================
# HERM.CHAT (Chatbot Embed)
# ============================================
# Your Herm.Chat widget ID or embed script identifier
NEXT_PUBLIC_HERMCHAT_WIDGET_ID=your_widget_id_here
